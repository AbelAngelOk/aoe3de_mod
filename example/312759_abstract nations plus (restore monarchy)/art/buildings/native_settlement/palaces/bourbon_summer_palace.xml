<animfile>
    <definebone>bone_falling_building</definebone>
    <submodel>
        dry dock
        <attachment>
            dock
            <component>
                dock
                <assetreference type="GrannyModel">
                    <file>buildings\native_settlement\palaces\bourbon_palace_Model</file>
                </assetreference>
            </component>
            <anim>Idle<component>dock</component></anim>
        </attachment>
        <attachment>
            collapse_smoke
            <component>
                collapse_smoke<assetreference type="popcornFx"><file>smoke\collapse_smoke_4x4.pkfx</file></assetreference>
            </component>
            <anim>Idle<component>collapse_smoke</component></anim>
        </attachment>
        <attachment>garden<include>buildings\native_settlement\palaces\bourbon_garden.xml</include></attachment>
        <component>
            dry dock
            <assetreference type="GrannyModel"><file>buildings\native_settlement\palaces\bourbon_palace_Model</file></assetreference>
            <attach a="garden" frombone="ATTACHPOINT" tobone="ATTACHPOINT" syncanims="0"></attach>
            <decal>
                <effecttype>bump</effecttype>
                <texture>buildings\state_capitol\textures\state_capitol_ground</texture>
                <selectedtexture>shadows_selections\selection_square_128x128</selectedtexture>
                <bumptexture>shadows_selections\flat_normal_black_spec</bumptexture>
                <width>18.25</width>
                <height>18.25</height>
            </decal>
        </component>
        <component>
            DEAD
            <assetreference type="GrannyModel">
                <file>buildings\1death_anim\Deathmodel</file>
            </assetreference>
            <attach a="dock" frombone="MASTER" tobone="bone_falling_building" syncanims="0"></attach>
        </component>
        <anim>
            Idle
            <component>dry dock</component>
            <simskeleton><model>buildings\state_capitol\state_capitol_damaged</model></simskeleton>
        </anim>
        <anim>
            Death
            <assetreference type="GrannyAnim">
                <file>buildings\1death_anim\Deathmodel_Animation</file>
            </assetreference>
            <component>DEAD</component>
            <attach a="collapse_smoke" frombone="ATTACHPOINT" tobone="ATTACHPOINT" syncanims="0"></attach>
        </anim>
    </submodel>
    <submodel>
        con 1
        <component>
            con 1
             <assetreference type="GrannyModel">
                <file>buildings\constructions\3x7_stage1</file>
            </assetreference>
            <decal>
                <effecttype>bump</effecttype>
                <texture>buildings\constructions\2x2_construction_decal</texture>
                <selectedtexture>shadows_selections\selection_square_128x128</selectedtexture>
                <bumptexture>shadows_selections\flat_normal_black_spec</bumptexture>
                <width>17.50</width>
                <height>9.50</height>
            </decal>
        </component>
        <anim>idle
            <component>con 1</component>
        </anim>
    </submodel>
    <submodel>
        con 2
        <component>
            con 2
            <assetreference type="GrannyModel">
                <file>buildings\constructions\3x7_stage2</file>
            </assetreference>
            <decal>
                <effecttype>bump</effecttype>
                <texture>buildings\constructions\2x2_construction_decal</texture>
                <selectedtexture>shadows_selections\selection_square_128x128</selectedtexture>
                <bumptexture>shadows_selections\flat_normal_black_spec</bumptexture>
                <width>17.50</width>
                <height>9.50</height>
            </decal>
        </component>
        <anim>idle
            <component>con 2</component>
        </anim>
    </submodel>
    <submodel>
        con 3
        <attachment>
            dock
            <component>
                dock
                <assetreference type="GrannyModel">
                    <file>buildings\native_settlement\palaces\bourbon_palace_con_Model</file>
                </assetreference>
            </component>
            <anim>Idle<component>dock</component></anim>
        </attachment>
        <component>
            con 3
            <assetreference type="GrannyModel">
                <file>buildings\constructions\3x7_stage3</file>
            </assetreference>
            <decal>
                <effecttype>bump</effecttype>
                <texture>buildings\constructions\2x2_construction_decal</texture>
                <selectedtexture>shadows_selections\selection_square_128x128</selectedtexture>
                <bumptexture>shadows_selections\flat_normal_black_spec</bumptexture>
                <width>17.50</width>
                <height>9.50</height>
            </decal>
            <attach a="dock" frombone="ATTACHPOINT" tobone="ATTACHPOINT" syncanims="0"></attach>
        </component>
        <anim>idle
            <component>con 3</component>
        </anim>
    </submodel>

    <component>
        ModelComp
        <logic type="BuildingCompletion">
            <p0><submodelref ref="con 1"></submodelref></p0>
            <p33><submodelref ref="con 2"></submodelref></p33>
            <p66><submodelref ref="con 3"></submodelref></p66>
            <p100><submodelref ref="dry dock"></submodelref></p100>
        </logic>
    </component>
</animfile>