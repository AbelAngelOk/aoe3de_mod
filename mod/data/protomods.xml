<?xml version="1.0" encoding="UTF-8"?>
<!-- Eastern European Expansion (EEX) - protomods.xml
     Defines new units for Hungary, Romania, and Finland.
     All assets (animfile, icon, tactics) reuse existing base-game files.
     Building train queues are modified additively (mergeMode='modify').

     ID ranges:
       77191xxx = Hungary units
       77192xxx = Romania units
       77193xxx = Finland units
-->
<protomods>

  <!-- ============================================================
       BUILDING MODIFICATIONS: add EEX units to existing buildings
       The enable/disable system (techtreemods.xml Age0 techs)
       controls which units are visible per active civilization.
       ============================================================ -->

  <!-- BARRACKS -->
  <Unit mergeMode="modify" name="Barracks">
    <!-- Hungary infantry (page 0 = train, page 1 = upgrades) -->
    <train  row="0" page="0" column="0">EEXHajduk</train>
    <train  row="0" page="0" column="1">EEXPandur</train>
    <train  row="0" page="0" column="2">EEXGrenz</train>
    <tech   row="0" page="1" column="0">EEXVeteranHajduk</tech>
    <tech   row="0" page="1" column="1">EEXVeteranPandur</tech>
    <tech   row="0" page="1" column="2">EEXVeteranGrenz</tech>
    <tech   row="1" page="1" column="0">EEXGuardHajduk</tech>
    <tech   row="1" page="1" column="1">EEXGuardPandur</tech>
    <tech   row="1" page="1" column="2">EEXGuardGrenz</tech>

    <!-- Romania infantry -->
    <train  row="1" page="0" column="0">EEXDorobant</train>
    <train  row="1" page="0" column="1">EEXRomanianPandur</train>
    <train  row="1" page="0" column="2">EEXSeimeni</train>
    <tech   row="2" page="1" column="0">EEXVeteranDorobant</tech>
    <tech   row="2" page="1" column="1">EEXVeteranRomanianPandur</tech>
    <tech   row="2" page="1" column="2">EEXVeteranSeimeni</tech>
    <tech   row="3" page="1" column="0">EEXGuardDorobant</tech>
    <tech   row="3" page="1" column="1">EEXGuardRomanianPandur</tech>
    <tech   row="3" page="1" column="2">EEXGuardSeimeni</tech>

    <!-- Finland infantry -->
    <train  row="2" page="0" column="0">EEXFinnishMusketeer</train>
    <train  row="2" page="0" column="1">EEXJaeger</train>
    <train  row="2" page="0" column="2">EEXKnekt</train>
    <tech   row="4" page="1" column="0">EEXVeteranFinnishMusketeer</tech>
    <tech   row="4" page="1" column="1">EEXVeteranJaeger</tech>
    <tech   row="4" page="1" column="2">EEXVeteranKnekt</tech>
    <tech   row="5" page="1" column="0">EEXGuardFinnishMusketeer</tech>
    <tech   row="5" page="1" column="1">EEXGuardJaeger</tech>
    <tech   row="5" page="1" column="2">EEXGuardKnekt</tech>
  </Unit>

  <!-- STABLE -->
  <Unit mergeMode="modify" name="Stable">
    <!-- Hungary cavalry -->
    <train  row="0" page="0" column="0">EEXMagyarHussar</train>
    <train  row="0" page="0" column="1">EEXHungarianDragoon</train>
    <tech   row="0" page="1" column="0">EEXVeteranMagyarHussar</tech>
    <tech   row="0" page="1" column="1">EEXVeteranHungarianDragoon</tech>
    <tech   row="1" page="1" column="0">EEXGuardMagyarHussar</tech>
    <tech   row="1" page="1" column="1">EEXGuardHungarianDragoon</tech>

    <!-- Romania cavalry -->
