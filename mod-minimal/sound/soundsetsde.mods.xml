<!--
  mod-minimal (Hungría): soundsets aditivos del Explorador húngaro. Cada soundset apunta a
  los .mp3 de sound/hungary/explorer/ (rutas relativas a la carpeta sound/). Referenciados
  desde explorer_snds.mods.xml. Root <soundsetdefmods> = merge aditivo (patrón "Just Poland").
-->
<soundsetdefmods>
  <soundset name="HungarianExplorerSelect" volume="0.9000" maxnum="4" distance="1.0000">
    <sound filename="hungary\explorer\hungarianexplorerselect1.mp3" volume="1.0000">
    </sound>
    <sound filename="hungary\explorer\hungarianexplorerselect2.mp3" volume="1.0000">
    </sound>
    <sound filename="hungary\explorer\hungarianexplorerselect3.mp3" volume="1.0000">
    </sound>
  </soundset>
  <soundset name="HungarianExplorerMove" volume="0.9000" maxnum="4" distance="1.0000">
    <sound filename="hungary\explorer\hungarianexplorermove1.mp3" volume="1.0000">
    </sound>
    <sound filename="hungary\explorer\hungarianexplorermove2.mp3" volume="1.0000">
    </sound>
    <sound filename="hungary\explorer\hungarianexplorermove3.mp3" volume="1.0000">
    </sound>
  </soundset>
  <soundset name="HungarianExplorerAttack" volume="1.0000" maxnum="1" distance="1.0000">
    <sound filename="hungary\explorer\hungarianexplorerattack.mp3" volume="1.0000">
    </sound>
  </soundset>
  <soundset name="HungarianExplorerClaim" volume="1.0000" maxnum="1" distance="1.0000">
    <sound filename="hungary\explorer\hungarianexplorerclaim.mp3" volume="1.0000">
    </sound>
  </soundset>
  <soundset name="HungarianExplorerDisabled" volume="1.0000" maxnum="1" distance="1.0000">
    <sound filename="hungary\explorer\hungarianexplorerdisabled.mp3" volume="1.0000">
    </sound>
  </soundset>
  <soundset name="HungarianExplorerRansomed" volume="1.0000" maxnum="1" distance="1.0000">
    <sound filename="hungary\explorer\hungarianexplorerransomed.mp3" volume="1.0000">
    </sound>
  </soundset>
  <soundset name="HungarianExplorerRevived" volume="1.0000" maxnum="1" distance="1.0000">
    <sound filename="hungary\explorer\hungarianexplorerrevived.mp3" volume="1.0000">
    </sound>
  </soundset>

