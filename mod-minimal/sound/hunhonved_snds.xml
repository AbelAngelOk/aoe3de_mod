<!--
  mod-minimal (Hungría): voz propia del Honvéd (proto HUNHonved). Usa los audios húngaros
  de sound/hungary/honved/ (basados en el mosquetero español), definidos como soundsets en
  soundsetsde.mods.xml. Grunt/Death/Creation quedan genéricos (no hay audios propios).
-->
<protounitsounddef>
  <protounit name="HUNHonved">
    <soundtype name="Select">
      <soundset name="HungarianMusketeerSelect">
      </soundset>
    </soundtype>
    <soundtype name="Grunt">
      <soundset name="GenericMaleGrunt">
      </soundset>
    </soundtype>
    <soundtype name="Death">
      <soundset name="GenericMaleDeath">
      </soundset>
    </soundtype>
    <soundtype name="Creation">
      <soundset name="MilitaryBirth">
      </soundset>
    </soundtype>
    <soundtype name="Acknowledge">
      <targetlogic>
        <choice name="default">
          <soundset name="HungarianMusketeerMove">
          </soundset>
        </choice>
        <choice name="enemy">
          <soundset name="HungarianMusketeerAttack">
          </soundset>
        </choice>
      </targetlogic>
    </soundtype>
  </protounit>
</protounitsounddef>
