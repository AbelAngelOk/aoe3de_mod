<!--
  mod-minimal: techtreemods.xml — identidad de tech-tree propia para HUNHungarians

  Cambio de enfoque: en vez de que civmods.xml apunte directamente a los nombres
  de tech de Germans (Age0German, ColonializeGerman, etc. — lo que hacía que
  HUNHungarians y Germans compartieran literalmente la misma instancia de tech
  por nombre), cada age tech de Hungría es ahora un tech "envoltorio" propio y
  con ID único que simplemente activa (TechStatus active) el tech real de
  Germans. Esto da a la civ una identidad de tech-tree 100% propia ("solo
  cambiale el id") sin transcribir el contenido completo (Age0German solo mide
  ~225 líneas de efectos; Industrialize/ImperializeGerman miden miles). Todos
  los efectos reales (enables, obtainables, políticos) siguen viniendo de los
  techs de Germans ya validados en el juego base.

  Mismo patrón de delegación que ya usan los políticos del mod completo (EEX):
  "<effect type=TechStatus status=active>EEXColonializeHungary</effect>"
  (ver docs/modding-reference.md).
-->
<techtreemods>
  <tech name="HUNAge0" type="Normal">
    <dbid>88881101</dbid>
    <status>UNOBTAINABLE</status>
    <flag>Shadow</flag>
    <effects>
      <effect type="TechStatus" status="active">Age0German</effect>
      <!-- Cambio 1: colonos -> carretones de colonos (civ-específico) -->
      <!-- Age0German habilita Settler; aquí lo deshabilitamos solo para Hungría -->
      <effect type="Data" amount="0.00" subtype="Enable" relativity="Assign">
        <target type="ProtoUnit">Settler</target>
      </effect>
      <!-- Habilitar el carretón propio de Hungría (buildlimit 50 viene del proto) -->
      <effect type="Data" amount="1.00" subtype="Enable" relativity="Absolute">
        <target type="ProtoUnit">HUNSettlerWagon</target>
      </effect>
      <!-- Barcos pesqueros: límite propio de 50 (base es 99); civ-específico -->
      <effect type="Data" amount="50.00" subtype="BuildLimit" relativity="Assign">
        <target type="ProtoUnit">FishingBoat</target>
      </effect>
      <!-- Cambio 2: el cuartel produce solo mosqueteros y hajduks -->
      <!-- Deshabilitar la infantería de cuartel alemana que activó Age0German -->
      <effect type="Data" amount="0.00" subtype="Enable" relativity="Assign">
        <target type="ProtoUnit">Crossbowman</target>
      </effect>
      <effect type="Data" amount="0.00" subtype="Enable" relativity="Assign">
        <target type="ProtoUnit">Skirmisher</target>
      </effect>
      <effect type="Data" amount="0.00" subtype="Enable" relativity="Assign">
        <target type="ProtoUnit">Pikeman</target>
      </effect>
      <effect type="Data" amount="0.00" subtype="Enable" relativity="Assign">
        <target type="ProtoUnit">Dopplesoldner</target>
      </effect>
      <!-- Habilitar el "mosquetero" propio (Honvéd) y el Hajduk -->
      <effect type="Data" amount="1.00" subtype="Enable" relativity="Absolute">
        <target type="ProtoUnit">HUNHonved</target>
      </effect>
      <effect type="Data" amount="1.00" subtype="Enable" relativity="Absolute">
        <target type="ProtoUnit">HUNHajduk</target>
      </effect>
      <!-- Cambio 4: quitar las mejoras alemanas del cuartel (ya no hay esas unidades).
           Se hacen unobtainable solo para Hungría (Age0German las hizo obtainable). -->
      <effect type="TechStatus" status="unobtainable">VeteranCrossbowmen</effect>
      <effect type="TechStatus" status="unobtainable">GuardCrossbowmen</effect>
      <effect type="TechStatus" status="unobtainable">ImperialCrossbowmen</effect>
      <effect type="TechStatus" status="unobtainable">VeteranPikemen</effect>
      <effect type="TechStatus" status="unobtainable">GuardPikemen</effect>
      <effect type="TechStatus" status="unobtainable">ImperialPikemen</effect>
      <effect type="TechStatus" status="unobtainable">VeteranDopplesoldners</effect>
      <effect type="TechStatus" status="unobtainable">GuardDopplesoldners</effect>
      <effect type="TechStatus" status="unobtainable">ImperialDopplesoldner</effect>
      <effect type="TechStatus" status="unobtainable">VeteranSkirmishersShadow</effect>
      <effect type="TechStatus" status="unobtainable">GuardSkirmishers</effect>
      <effect type="TechStatus" status="unobtainable">ImperialSkirmishers</effect>
      <effect type="TechStatus" status="unobtainable">RGPrussianNeedleGun</effect>
      <effect type="TechStatus" status="unobtainable">ImperialNeedleGun</effect>
      <!-- Cambio 4: habilitar (obtainable) las mejoras propias: 3 Honvéd + 3 Hajduk.
           Los prereqs de edad/nivel controlan cuándo se pueden investigar. -->
      <effect type="TechStatus" status="obtainable">HUNVeteranHonved</effect>
      <effect type="TechStatus" status="obtainable">HUNGuardHonved</effect>
      <effect type="TechStatus" status="obtainable">HUNImperialHonved</effect>
      <effect type="TechStatus" status="obtainable">HUNVeteranHajduk</effect>
      <effect type="TechStatus" status="obtainable">HUNGuardHajduk</effect>
      <effect type="TechStatus" status="obtainable">HUNImperialHajduk</effect>
      <!-- Cambio 6: caballería. Deshabilitar la del Establo alemán (Uhlan, WarWagon)
           y sus mejoras; habilitar Magyar Hussar + Crabat propios. -->
      <effect type="Data" amount="0.00" subtype="Enable" relativity="Assign">
        <target type="ProtoUnit">Uhlan</target>
      </effect>
      <effect type="Data" amount="0.00" subtype="Enable" relativity="Assign">
        <target type="ProtoUnit">WarWagon</target>
      </effect>
      <effect type="TechStatus" status="unobtainable">VeteranUhlans</effect>
      <effect type="TechStatus" status="unobtainable">RGCzapkaUhlans</effect>
      <effect type="TechStatus" status="unobtainable">ImperialCzapkaUhlans</effect>
      <effect type="TechStatus" status="unobtainable">ImperialWarWagons</effect>
      <effect type="TechStatus" status="unobtainable">GuardWarWagons</effect>
      <effect type="Data" amount="1.00" subtype="Enable" relativity="Absolute">
        <target type="ProtoUnit">HUNMagyarHussar</target>
      </effect>
      <effect type="Data" amount="1.00" subtype="Enable" relativity="Absolute">
        <target type="ProtoUnit">HUNCrabat</target>
      </effect>
      <effect type="TechStatus" status="obtainable">HUNGuardMagyarHussar</effect>
      <effect type="TechStatus" status="obtainable">HUNImperialMagyarHussar</effect>
      <effect type="TechStatus" status="obtainable">HUNGuardCrabat</effect>
      <effect type="TechStatus" status="obtainable">HUNImperialCrabat</effect>
    </effects>
  </tech>
