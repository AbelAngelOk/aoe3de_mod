      <!-- Civ name and description -->
      <string _locid="77181001">Hungarians</string>
      <string _locid="77181002">The Hungarians, heirs to the Magyar warriors, combine the traditions of the East with the might of Central European empire. Their Magyar Hussars are among the finest cavalry in the world, while Hajduk light infantry provide a versatile and cost-effective fighting force.</string>

      <!-- Home city and hero -->
      <string _locid="77181003">Budapest</string>
      <string _locid="77181004">The Magyar Chieftain</string>

      <!-- Explorer -->
      <string _locid="77181010">Hungarian Explorer</string>
      <string _locid="77181011">A seasoned Magyar warrior who leads Hungarian expeditions into the New World.</string>
      <string _locid="77181012">Hungarian Explorer</string>

      <!-- Hajduk -->
      <string _locid="77181020">Hajduk</string>
      <string _locid="77181021">Hungarian light infantry armed with muskets. The Hajduks were irregular soldiers who fought for both the Habsburgs and Hungarian nobles throughout the 17th century. Fast to train and cost-effective, but with lower hit points than standard Musketeers.</string>
      <string _locid="77181022">Hajduk</string>

      <!-- Pandur -->
      <string _locid="77181030">Pandur</string>
      <string _locid="77181031">Hungarian light infantry skirmisher effective against cavalry. The Pandurs were irregular border troops famous for their ability to harass enemy formations. Available in Fortress Age.</string>
      <string _locid="77181032">Pandur</string>

      <!-- Grenz -->
      <string _locid="77181040">Grenz Infantry</string>
      <string _locid="77181041">Heavy Hungarian border infantry armed with a pike. The Grenzer served as the military frontier guard of the Habsburg Empire, protecting against Ottoman raids. Strong against cavalry.</string>
      <string _locid="77181042">Grenz Infantry</string>

      <!-- Magyar Hussar -->
      <string _locid="77181050">Magyar Hussar</string>
      <string _locid="77181051">Elite Hungarian shock cavalry. The Magyar Hussars were the pride of the Hungarian military, known throughout Europe for their speed and ferocity in battle. Can be trained from Fortress Age.</string>
      <string _locid="77181052">Magyar Hussar</string>

      <!-- Hungarian Dragoon -->
      <string _locid="77181060">Hungarian Dragoon</string>
      <string _locid="77181061">Ranged cavalry that can fight both mounted and on foot. Hungarian dragoons provided flexible mobile firepower on the battlefield.</string>
      <string _locid="77181062">Hungarian Dragoon</string>

